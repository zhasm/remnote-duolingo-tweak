root = true

[*]
indent_style = space
indent_size = 4
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 80
[*.{js,jsx,ts,tsx}]
# JavaScript/TypeScript-specific rules
indent_size = 2
max_line_length = 100  # Adjust based on your team's preference

[*.json]
indent_size = 2
